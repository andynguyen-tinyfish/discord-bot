# Required secrets/config
DISCORD_BOT_TOKEN=
GEMINI_API_KEY=
ADMIN_PASSWORD=

# Use Railway Volume path in production (example: /data/app.db)
DATABASE_PATH=./app.db
KNOWLEDGE_UPLOAD_DIR=/data/knowledge_uploads

# Optional: separate Flask session secret for admin mode
ADMIN_SESSION_SECRET=

# Optional bootstrap defaults (used only if runtime_settings table is empty)
SOURCE_CHANNEL_IDS=
REMINDER_CHANNEL_ID=
TIMEZONE=Asia/Bangkok
NIGHTLY_SUMMARY_HOUR=0
NIGHTLY_SUMMARY_MINUTE=5
MORNING_POST_HOUR=9
MORNING_POST_MINUTE=0
DRY_RUN=false
DRY_RUN_CHANNEL_ID=
ALLOWED_USER_IDS=
ALLOWED_ROLE_IDS=
